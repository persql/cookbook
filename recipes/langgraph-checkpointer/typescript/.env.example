# PerSQL — create a token at https://console.persql.com
PERSQL_TOKEN=psql_live_s0_...
# namespace/database-slug — created automatically on first run
PERSQL_DATABASE=myteam/langgraph

# LLM for the interactive agent. Any OpenAI-compatible endpoint works.
OPENAI_API_KEY=sk-...
# Optional gateway base URL. Unset -> the default OpenAI API.
# OPENAI_BASE_URL=https://your-gateway.example.com/v1
# OPENAI_MODEL=gpt-4o-mini
# THREAD_ID=session-1
