# Register an OAuth app in the console to get these. The `database` scope
# provisions a private database in the signed-in user's own namespace and
# returns a token scoped to exactly that database.
PERSQL_CLIENT_ID=psqlrp_...
PERSQL_REDIRECT_URI=https://app.example.com/callback

# Optional: point at staging instead of production.
# PERSQL_API_URL=https://api-staging.persql.com
